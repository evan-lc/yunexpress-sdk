{
  "name": "yunexpress-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the YunExpress OpenAPI with sandbox and production auth abstractions.",
  "keywords": [
    "logistics",
    "node",
    "sdk",
    "shipping",
    "yunexpress"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "lint": "vp lint",
    "format": "vp fmt",
    "typecheck": "vp exec tsc --noEmit -p tsconfig.json",
    "test": "vp test",
    "check": "vp check",
    "pack:check": "vp pm pack --dry-run",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
